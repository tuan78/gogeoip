# HTTP port (default: 8080)
PORT=8080

# MaxMind GeoLite2 credentials (required)
# Sign up at https://www.maxmind.com/en/geolite2/signup
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Path to cache the downloaded .mmdb file
GEO_DB_PATH=/tmp/geolite2-country.mmdb

# How often to re-download the database (default: 24h)
GEO_DB_REFRESH_INTERVAL=24h

# Redis caching (optional - leave empty to disable)
REDIS_ADDR=
REDIS_PASSWORD=

# Redis key prefix for /lookup cache entries.
# Final key format: {prefix}{ip} — e.g. "gogeoip:lookup:8.8.8.8"
REDIS_LOOKUP_KEY_PREFIX=gogeoip:lookup:

# How long a /lookup result is cached (default: 24h). Set to 0s to disable expiry.
REDIS_LOOKUP_CACHE_TTL=24h
